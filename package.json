{
  "name": "wangchuan",
  "version": "6.0.0",
  "description": "忘川 · AI 记忆同步系统 — 智能体记忆永不遗失",
  "bin": {
    "wangchuan": "./dist/bin/wangchuan.js"
  },
  "files": [
    "dist/",
    "skill/",
    ".wangchuan/config.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/wangchuan.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx bin/wangchuan.ts",
    "test": "node --import tsx/esm --test test/crypto.test.ts test/json-field.test.ts test/sync.test.ts test/sync-history.test.ts test/merge.test.ts test/git.test.ts test/sync-lock.test.ts test/migrate.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "memory",
    "sync",
    "agent",
    "claude",
    "gemini",
    "openclaw",
    "encryption"
  ],
  "author": "SUpermin6u",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SUpermin6u/wangchuan.git"
  },
  "homepage": "https://github.com/SUpermin6u/wangchuan",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.1.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.19.0"
  },
  "type": "module"
}
